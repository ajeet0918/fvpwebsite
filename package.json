{
  "name": "agri-b2b-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "build:staging": "tsc --noEmit -p tsconfig.app.json && vite build --mode staging",
    "build:production": "tsc --noEmit -p tsconfig.app.json && vite build --mode production",
    "preview": "vite preview",
    "quality": "npm run lint && npm run build:production && npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.18"
  }
}
